<Window x:Class="CRUD.Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRUD"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Título -->
                <RowDefinition Height="Auto"/> <!-- Campo Usuário -->
                <RowDefinition Height="Auto"/> <!-- Campo Senha -->
                <RowDefinition Height="Auto"/> <!-- Botão Login -->
                <RowDefinition Height="Auto"/> <!-- Botão Cadastrar -->
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0" Text="Bem-vindo" 
                       FontSize="28" FontWeight="Bold" Foreground="#333333"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Campo Usuário -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Usuário:" Margin="0,0,0,5" Foreground="#666666"/>
                <TextBox x:Name="TxtUsuario" Height="35" Padding="5" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Campo Senha -->
            <StackPanel Grid.Row="2" Margin="0,0,0,25">
                <TextBlock Text="Senha:" Margin="0,0,0,5" Foreground="#666666"/>
                <PasswordBox x:Name="TxtSenha" Height="35" Padding="5" VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Botão Login -->
            <Button Grid.Row="3" x:Name="BtnLogin" Content="Entrar" 
                    Height="40" Background="#007ACC" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0" Margin="0,0,0,15"
                    Click="BtnLogin_OnClick"/>

            <!-- Botão Cadastrar -->
            <Button Grid.Row="4" x:Name="BtnCadastrar" Content="Criar uma conta" 
                    Height="30" Background="Transparent" Foreground="#007ACC" 
                    BorderThickness="0" Cursor="Hand"
                    Click="BtnCadastrar_OnClick"/>
        </Grid>
        <StackPanel Margin="30" VerticalAlignment="Center">
            <TextBlock Text="Nome:" Margin="0,0,0,5" />
            <TextBox x:Name="txtNome" Height="30" Margin="0,0,0,15" Padding="5"/>
            
            <TextBlock Text="username:" Margin="0,0,0,5" />
             <TextBox x:Name="txtUsername" Height="30" Margin="0,0,0,15" Padding="5" />
                 
            <TextBlock Text="email" Margin="0,0,0,5" />
            <TextBox x:Name="txtEmail" Height="30" Margin="0,0,0,15" Padding="5" />
            
            <TextBlock Text="senha:" Margin="0,0,0,5" />
            <PasswordBox x:Name="txtSenha" Height="30" Margin="0,0,0,15" Padding="5" />
            
            <Button x:Name="btnCadastrar" Content="Cadastrar" Height="33"
                    Click="BtnCadastrar_OnClick" Background="DarkCyan" Foreground="DarkGray" />
                    
  </StackPanel>                  
 </Grid>               
    </Window> 
            